// .env.example
# Firebase Configuration
VITE_FIREBASE_API_KEY=seu_api_key_aqui
VITE_FIREBASE_AUTH_DOMAIN=seu_auth_domain_aqui
VITE_FIREBASE_PROJECT_ID=seu_project_id_aqui
VITE_FIREBASE_STORAGE_BUCKET=seu_storage_bucket_aqui
VITE_FIREBASE_MESSAGING_SENDER_ID=seu_sender_id_aqui
VITE_FIREBASE_APP_ID=seu_app_id_aqui

# Super Admin Email (NUNCA COMPARTILHE ESTE ARQUIVO!)
VITE_SUPER_ADMIN_EMAIL=seu_email_super_admin_aqui

# Encryption Key (para dados sensíveis como PIX)
VITE_ENCRYPTION_KEY=sua_chave_de_encriptacao_aqui
